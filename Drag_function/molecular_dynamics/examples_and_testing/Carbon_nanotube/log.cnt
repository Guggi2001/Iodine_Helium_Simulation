Deleted 71 angles, new total = 1969
Deleted 187 dihedrals, new total = 3843
Deleted 31 impropers, new total = 639

# 4) Monitoring
variable n_carbon equal count(carbon_atoms)
variable n_top equal count(cnt_top)
variable n_bot equal count(cnt_bot)
variable n_mid equal count(cnt_mid)
# 5) Run
write_dump all image carbon_nanotube.ppm element type size 1000 400 zoom 6 shiny      0.3 fsaa yes bond atom 0.8 view 0 90 box no 0.0 axes no 0.0 0.0 modify backcolor      white adiam 1 0.85 bdiam 1 1.0
